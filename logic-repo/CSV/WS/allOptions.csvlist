#AURORA_DATA_SYSTEMS_BUILD
#  Record the build configuration
OPT_AUG,BUILD_INDEX , FW_BUILD_AURORA_DATA_SYSTEMS_CAS1
OPT_AUG,BLE_OPTIONS_2_INDEX , BLE_WAVELYNX

#  Enable BLE, but ignore BLE credentials
OPT_AUG,OPERATION_INDEX , ENABLE_BLE
OPT_AUG,BLE_OPTIONS_1_INDEX , BLE_IGNORE_CREDENTIALS_MASK

#  No 125 KHz Support

#  13.56 MHz High Frequency RF Front End
OPT_AUG,OPERATION_INDEX , ENABLE_HF_RF

#  Tamper Signal Line Enabled
OPT_AUG,OPERATION_INDEX , ENABLE_TAMPER_CNTRL_LINE

#  Enable Host Controlled AV
OPT_AUG,OPERATION_INDEX , ENABLE_HOST_CNTL_AV

# 
#  Default LEAF IP - Kc1 - Cc App AID - EV1_CARD_KEY_1
#  Ignore custom key sets.
# 
OPT,LEAF_IP_DEF_INDEX , 40
OPT,LEAF_IP_KS1_INDEX , LEAF_IP_IGNORE_KEYSET_MASK
OPT,LEAF_IP_KS2_INDEX , LEAF_IP_IGNORE_KEYSET_MASK
OPT,LEAF_IP_KS3_INDEX , LEAF_IP_IGNORE_KEYSET_MASK

#  Add all RF protocols
RF,0, CP_ISO_14443A
RF,1, CP_ISO_15693
RF,2, CP_PICO_15693
#  Smart card application support

APP,CT_MF_DESFIRE_EV1_2,0 , CA_LEAF_IP
APP,CT_MF_DESFIRE_EV1_2,1, CA_FEATURES_KEYS
APP,CT_MF_DESFIRE_EV1_2,2, CA_CSN

#BARRY_BUILD
#Model type 5,6,7
HW,TYPE,6
#ENABLE/DISABLE ASK
#HW,ASK,ENABLE

#  Record the build configuration
OPT_AUG,	BUILD_INDEX ,FW_BUILD_BARRY
OPT_AUG,	BLE_OPTIONS_2_INDEX ,BLE_WAVELYNX

#  Enable BLE
OPT_AUG,	OPERATION_INDEX ,ENABLE_BLE
OPT_AUG,	BLE_OPTIONS_1_INDEX ,BLE_IGNORE_CREDENTIALS_MASK

#  No FSK or ASK 125 KHz Low Frequency support

#  13.56 MHz High Frequency RF Front End
OPT_AUG,	OPERATION_INDEX ,ENABLE_HF_RF

#  Tamper Signal Line Enabled
OPT_AUG,	OPERATION_INDEX ,ENABLE_TAMPER_CNTRL_LINE	

#  Enable Host Controlled AV
OPT_AUG,	OPERATION_INDEX ,ENABLE_HOST_CNTL_AV

# 
#  Default LEAF IP - Kc1 - Cc App AID - EV1_CARD_KEY_1
#  Ignore custom key sets.
# 
OPT,	LEAF_IP_DEF_INDEX ,40
OPT,	LEAF_IP_KS1_INDEX ,LEAF_IP_IGNORE_KEYSET_MASK
OPT,	LEAF_IP_KS2_INDEX ,LEAF_IP_IGNORE_KEYSET_MASK
OPT,	LEAF_IP_KS3_INDEX ,LEAF_IP_IGNORE_KEYSET_MASK

#  Only ISO14443A cards are supported, Leaf and Configuration cards
RF,0 ,CP_ISO_14443A
#for (i=0 i<MAX_VALID_CARD_TYPES; i++)
APP,ALL ,CA_NONE

#  Smart card application support
APP,CT_MF_CLASSIC      ,0 ,CA_BARRY
APP,CT_MF_DESFIRE_EV1_2,0 ,CA_LEAF_IP
APP,CT_MF_DESFIRE_EV1_2,1 ,CA_FEATURES_KEYS

#BBH_BUILD
#  Record the build configuration
OPT_AUG,BUILD_INDEX , FW_BUILD_BBH_CBB1
# BUILD_INDEX , FW_BUILD_BBH_CBB2
OPT_AUG,BLE_OPTIONS_2_INDEX , BLE_WAVELYNX

#  Enable BLE, but ignore BLE credentials
OPT_AUG,OPERATION_INDEX , ENABLE_BLE
#if ( (FW_BUILD_BBH_CBB1 ,= (BUILD_INDEX & FW_BUILD_MASK)) )
OPT_AUG,BLE_OPTIONS_1_INDEX , BLE_IGNORE_CREDENTIALS_MASK


#  FSK 125 KHz Low Frequency RF Front End
#  STD Release
OPT_AUG,OPERATION_INDEX , ENABLE_FSK_RF

#  There is no support for ASK.

# 
#  BBH LED operations (Minimum Brightness)
#   Red LED On is idle state
#   Green blink on card reads
#   Blue LED PWM , 10% (1)
#   Green LED PWM , 10% (1)
#   Red LED PWM , 10% (1)
# 
#OPT,LED_OPTIONS_1_INDEX ,0x1110  | wl.RED_LED | (GREEN_LED << 2))
LED, 0x1110,RED_LED,GREEN_LED

#  13.56 MHz High Frequency RF Front End
OPT_AUG,OPERATION_INDEX , ENABLE_HF_RF

#  Tamper Signal Line Enabled
OPT_AUG,OPERATION_INDEX , ENABLE_TAMPER_CNTRL_LINE

#  Enable Host Controlled AV
OPT_AUG,OPERATION_INDEX , ENABLE_HOST_CNTL_AV

# 
#  Default LEAF IP - Kc1 - Cc App AID - EV1_CARD_KEY_1
#  Ignore custom key sets.
# 
OPT,LEAF_IP_DEF_INDEX , 40
OPT,LEAF_IP_KS1_INDEX , LEAF_IP_IGNORE_KEYSET_MASK
OPT,LEAF_IP_KS2_INDEX , LEAF_IP_IGNORE_KEYSET_MASK
OPT,LEAF_IP_KS3_INDEX , LEAF_IP_IGNORE_KEYSET_MASK

#  Add all RF protocols
RF,0, CP_ISO_14443A
RF,1, CP_ISO_15693
RF,2, CP_PICO_15693
#  Smart card application support
APP,CT_MF_DESFIRE_EV1_2,0, CA_LEAF_IP
APP,CT_MF_DESFIRE_EV1_2,1, CA_FEATURES_KEYS
APP,CT_MF_DESFIRE_EV1_2,2, CA_CSN


#BBH_BUILD
#  Record the build configuration
OPT_AUG,BUILD_INDEX , FW_BUILD_BBH_CBB2
OPT_AUG,BLE_OPTIONS_2_INDEX , BLE_WAVELYNX

#  Enable BLE, but ignore BLE credentials
OPT_AUG,OPERATION_INDEX , ENABLE_BLE


#  FSK 125 KHz Low Frequency RF Front End
#  STD Release
OPT_AUG,OPERATION_INDEX , ENABLE_FSK_RF

#  There is no support for ASK.

# 
#  BBH LED operations (Minimum Brightness)
#   Red LED On is idle state
#   Green blink on card reads
#   Blue LED PWM , 10% (1)
#   Green LED PWM , 10% (1)
