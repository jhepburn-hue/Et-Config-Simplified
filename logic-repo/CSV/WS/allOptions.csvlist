#   Blue LED PWM , 50% (5)
#   Green LED PWM , 50% (5)
#   Red LED PWM , 60% (6)
# 
OPT,LED_OPTIONS_1_INDEX , DEFAULT_LED_PWM_DUTY_CYCLES
OPT_MASK,LED_OPTIONS_2_INDEX , ~(BLUE_LED_IDLE_COLOR_MASK)
#  Custom blink time of 0 seconds, so really, no blink on card read.
OPT,CARD_AV_OPTIONS_2_INDEX , CARD_AV_LED_ENABLED

# 
#  Custom beep time of 0 seconds, so really, no beep on card read.
# 
